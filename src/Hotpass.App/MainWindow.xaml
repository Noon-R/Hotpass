<Window x:Class="Hotpass.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Hotpass.App.Views"
        xmlns:vm="clr-namespace:Hotpass.App.ViewModels"
        Title="Hotpass — where the frame goes" Height="900" Width="1280"
        Background="{StaticResource BgBrush}"
        FontFamily="{StaticResource UiFont}" FontSize="14"
        Foreground="{StaticResource InkBrush}"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <!-- キャプチャチップの役割別ボタン -->
        <Style x:Key="ChipActionButton" TargetType="Button" BasedOn="{StaticResource SubtleButton}">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <!-- header -->
            <Border BorderBrush="{StaticResource HairBrush}" BorderThickness="0,0,0,1" Background="{StaticResource SurfaceBrush}">
                <StackPanel Orientation="Horizontal" MaxWidth="1180" Margin="28,15" HorizontalAlignment="Left">
                    <!-- ロゴマーク(高さ違いの4本バー) -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Height="20">
                        <Rectangle Width="4" Height="9" Fill="{StaticResource InkBrush}" RadiusX="1" RadiusY="1" VerticalAlignment="Bottom" Margin="0,0,3,0"/>
                        <Rectangle Width="4" Height="20" Fill="{StaticResource AccentBrush}" RadiusX="1" RadiusY="1" VerticalAlignment="Bottom" Margin="0,0,3,0"/>
                        <Rectangle Width="4" Height="13" Fill="{StaticResource InkBrush}" RadiusX="1" RadiusY="1" VerticalAlignment="Bottom" Margin="0,0,3,0"/>
                        <Rectangle Width="4" Height="6" Fill="{StaticResource InkBrush}" RadiusX="1" RadiusY="1" VerticalAlignment="Bottom"/>
                    </StackPanel>
                    <TextBlock Text="Hotpass" FontFamily="{StaticResource DisplayFont}" FontSize="18" FontWeight="Bold" Margin="13,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Text="where the frame goes — triage first, debug in PIX" Style="{StaticResource LabelText}" Margin="12,2,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Grid MaxWidth="1180" Margin="28,0">
                <StackPanel>
                    <!-- capture rail -->
                    <Border BorderBrush="{StaticResource HairBrush}" BorderThickness="0,0,0,1" Padding="0,18,0,20">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <TextBlock Text="Open captures" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Ink2Brush}" VerticalAlignment="Center"/>
                                <Border Style="{StaticResource ToggleGroup}" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal">
                                        <ToggleButton Style="{StaticResource ToggleChip}" Content="Single"
                                                      IsChecked="{Binding IsSingleMode, Mode=OneWay}"
                                                      Command="{Binding SetModeCommand}" CommandParameter="single"/>
                                        <ToggleButton Style="{StaticResource ToggleChip}" Content="Compare"
                                                      IsChecked="{Binding IsCompareMode, Mode=OneWay}"
                                                      Command="{Binding SetModeCommand}" CommandParameter="compare"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <WrapPanel>
                                <ItemsControl ItemsSource="{Binding Open}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,10,12,2">
                                                <Border MinWidth="228" Padding="16,13" Background="{StaticResource SurfaceBrush}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="BorderBrush" Value="{StaticResource Hair2Brush}"/>
                                                            <Setter Property="BorderThickness" Value="1.5"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Role}" Value="{x:Static vm:ChipRole.Viewing}">
                                                                    <Setter Property="BorderBrush" Value="{StaticResource InkBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Role}" Value="{x:Static vm:ChipRole.Base}">
                                                                    <Setter Property="BorderBrush" Value="{StaticResource InkBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Role}" Value="{x:Static vm:ChipRole.Compare}">
                                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,18,4">
                                                            <TextBlock Text="{Binding FileName}" FontWeight="Bold" FontSize="14"/>
                                                            <Border Padding="7,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{StaticResource NsightBadgeBg}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsPix}" Value="True">
                                                                                <Setter Property="Background" Value="{StaticResource PixBadgeBg}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding SourceBadge}" FontSize="9.5" FontWeight="Bold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{StaticResource NsightBadgeFg}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsPix}" Value="True">
                                                                                    <Setter Property="Foreground" Value="{StaticResource PixBadgeFg}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding ChipMeta}" Style="{StaticResource LabelText}" FontSize="11.5"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,1">
                                                            <TextBlock Style="{StaticResource NumText}" FontFamily="{StaticResource DisplayFont}" FontSize="19" FontWeight="Bold">
                                                                <Run Text="{Binding TotalText, Mode=OneWay}"/><Run Text=" ms" FontSize="12" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold"/>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding DeltaText}" FontSize="12" FontWeight="Bold" Margin="8,4,0,0" Typography.NumeralAlignment="Tabular">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{StaticResource GoodBrush}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsOverBudget}" Value="True">
                                                                                <Setter Property="Foreground" Value="{StaticResource BadBrush}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding ProvidesText}" Style="{StaticResource LabelText}" FontSize="11"/>
                                                        <!-- Single: View / Compare: Base+Compare -->
                                                        <StackPanel Orientation="Horizontal" Margin="0,11,0,0">
                                                            <Button Style="{StaticResource ChipActionButton}" MinWidth="90"
                                                                    Command="{Binding DataContext.ViewCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Visibility="{Binding DataContext.IsCompareMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                                                <Button.Content>
                                                                    <TextBlock>
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Text" Value="View"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Role}" Value="{x:Static vm:ChipRole.Viewing}">
                                                                                        <Setter Property="Text" Value="Viewing"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Button.Content>
                                                            </Button>
                                                            <StackPanel Orientation="Horizontal"
                                                                        Visibility="{Binding DataContext.IsCompareMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                                                <Button Content="Base" MinWidth="70" Margin="0,0,7,0"
                                                                        Command="{Binding DataContext.SetBaseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource ChipActionButton}">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Role}" Value="{x:Static vm:ChipRole.Base}">
                                                                                    <Setter Property="Background" Value="{StaticResource InkBrush}"/>
                                                                                    <Setter Property="Foreground" Value="#15181D"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                                <Button Content="Compare" MinWidth="80"
                                                                        Command="{Binding DataContext.SetCompareCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource ChipActionButton}">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Role}" Value="{x:Static vm:ChipRole.Compare}">
                                                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                                                    <Setter Property="Foreground" Value="#0D1523"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                                <!-- 役割タグ(チップ上端に重ねる) -->
                                                <Border Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14,-9,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Role}" Value="{x:Static vm:ChipRole.Base}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Setter Property="Background" Value="{StaticResource InkBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Role}" Value="{x:Static vm:ChipRole.Compare}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="9.5" FontWeight="Bold" Foreground="#15181D">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Role}" Value="{x:Static vm:ChipRole.Base}">
                                                                        <Setter Property="Text" Value="BASE"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Role}" Value="{x:Static vm:ChipRole.Compare}">
                                                                        <Setter Property="Text" Value="COMPARE"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                                <!-- 閉じる -->
                                                <Button Content="×" FontSize="15" Foreground="{StaticResource FaintBrush}" Background="Transparent"
                                                        BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,16,10,0"
                                                        Padding="4,0" Cursor="Hand"
                                                        Command="{Binding DataContext.CloseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- ＋ Add capture -->
                                <Grid Margin="0,10,0,2">
                                    <ToggleButton x:Name="AddToggle" MinWidth="140" MinHeight="120" Cursor="Hand">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="{StaticResource SurfaceBrush}" BorderThickness="1.5">
                                                    <Border.BorderBrush>
                                                        <DrawingBrush Viewport="0,0,8,8" ViewportUnits="Absolute" TileMode="Tile">
                                                            <DrawingBrush.Drawing>
                                                                <GeometryDrawing Brush="{StaticResource Hair2Brush}">
                                                                    <GeometryDrawing.Geometry>
                                                                        <GeometryGroup>
                                                                            <RectangleGeometry Rect="0,0,4,4"/>
                                                                        </GeometryGroup>
                                                                    </GeometryDrawing.Geometry>
                                                                </GeometryDrawing>
                                                            </DrawingBrush.Drawing>
                                                        </DrawingBrush>
                                                    </Border.BorderBrush>
                                                    <TextBlock Text="＋ Add capture" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <Popup IsOpen="{Binding IsChecked, ElementName=AddToggle, Mode=TwoWay}" StaysOpen="False"
                                           PlacementTarget="{Binding ElementName=AddToggle}" Placement="Bottom" VerticalOffset="6"
                                           AllowsTransparency="True">
                                        <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource Hair2Brush}"
                                                BorderThickness="1.5" Padding="6" MinWidth="250">
                                            <StackPanel>
                                                <ItemsControl ItemsSource="{Binding Available}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Click="AddPopupItem_Click"
                                                                    Command="{Binding DataContext.AddSampleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource SubtleButton}">
                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                        <Setter Property="BorderThickness" Value="0"/>
                                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                                    </Style>
                                                                </Button.Style>
                                                                <Grid MinWidth="220">
                                                                    <TextBlock Text="{Binding FileName}" FontSize="13" Foreground="{StaticResource InkBrush}"/>
                                                                    <TextBlock HorizontalAlignment="Right" FontSize="11" Foreground="{StaticResource MutedBrush}" Typography.NumeralAlignment="Tabular">
                                                                        <Run Text="{Binding SourceBadge, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding TotalText, Mode=OneWay}"/><Run Text=" ms"/>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Separator Background="{StaticResource HairBrush}" Margin="4,4"/>
                                                <Button Click="AddPopupItem_Click" Command="{Binding OpenFileCommand}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SubtleButton}">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                                        </Style>
                                                    </Button.Style>
                                                    <TextBlock Text="Open .wpix file…" FontSize="13" Foreground="{StaticResource AccentBrush}"/>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- empty state -->
                    <StackPanel Visibility="{Binding HasCaptures, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"
                                Margin="0,72" HorizontalAlignment="Center">
                        <TextBlock Text="No captures open" FontFamily="{StaticResource DisplayFont}" FontSize="19"
                                   Foreground="{StaticResource Ink2Brush}" HorizontalAlignment="Center" Margin="0,0,0,7"/>
                        <TextBlock Text="Add a PIX capture or Nsight trace to begin." Style="{StaticResource LabelText}" FontSize="13" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- content -->
                    <Grid Visibility="{Binding HasCaptures, Converter={StaticResource BoolToVis}}">
                        <views:SingleView Visibility="{Binding IsCompareMode, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                        <views:CompareView Visibility="{Binding IsCompareMode, Converter={StaticResource BoolToVis}}"/>
                    </Grid>

                    <!-- footer -->
                    <TextBlock Style="{StaticResource LabelText}" FontSize="11.5" Margin="0,34,0,40" MaxWidth="780"
                               HorizontalAlignment="Left" TextWrapping="Wrap" LineHeight="20"
                               Text="Hotpass normalizes PIX GPU captures and Nsight GPU traces into one per-pass view. What a capture can show depends on the file — a PIX capture carries occupancy and limiter, a Nsight trace carries occupancy and speed-of-light; missing fields read “—”. For shader, resource and pixel-level work, open the flagged event in PIX."/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Window>
