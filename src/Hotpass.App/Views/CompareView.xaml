<UserControl x:Class="Hotpass.App.Views.CompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:Hotpass.App.Controls"
             xmlns:vm="clr-namespace:Hotpass.App.ViewModels">
    <UserControl.Resources>
        <Style x:Key="RoleTag" TargetType="Border">
            
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="RoleTagText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9.5"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- base/compare 未選択 -->
        <StackPanel Visibility="{Binding Compare, Converter={StaticResource NullToVis}, ConverterParameter=invert}"
                    Margin="0,72" HorizontalAlignment="Center">
            <TextBlock Text="Pick a base and a compare" FontFamily="{StaticResource DisplayFont}" FontSize="19"
                       Foreground="{StaticResource Ink2Brush}" HorizontalAlignment="Center" Margin="0,0,0,7"/>
            <TextBlock Text="Use the Base and Compare buttons on two captures above." Style="{StaticResource LabelText}"
                       FontSize="13" HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel Visibility="{Binding Compare, Converter={StaticResource NullToVis}}">
            <!-- 方向バナー: BASE → COMPARE を徹底明示 -->
            <Border BorderBrush="{StaticResource HairBrush}" BorderThickness="0,1,0,1" Margin="0,28,0,0" Padding="0,16">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Border Style="{StaticResource RoleTag}" Background="{StaticResource InkBrush}">
                            <TextBlock Text="BASE" Style="{StaticResource RoleTagText}" Foreground="#15181D"/>
                        </Border>
                        <TextBlock VerticalAlignment="Center" Margin="10,0,0,0">
                            <Run Text="{Binding Compare.Base.FileName, Mode=OneWay}" FontFamily="{StaticResource DisplayFont}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}"/>
                            <Run Text=" "/><Run Text="{Binding Compare.Base.SourceBadge, Mode=OneWay}" FontSize="12" Foreground="{StaticResource MutedBrush}"/><Run Text=" · " FontSize="12" Foreground="{StaticResource MutedBrush}"/><Run Text="{Binding Compare.Base.TotalText, Mode=OneWay}" FontSize="12" Foreground="{StaticResource MutedBrush}"/><Run Text=" ms" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                        </TextBlock>
                        <TextBlock Text="→" FontSize="16" Foreground="{StaticResource FaintBrush}" Margin="16,0" VerticalAlignment="Center"/>
                        <Border Style="{StaticResource RoleTag}" Background="{StaticResource AccentBrush}">
                            <TextBlock Text="COMPARE" Style="{StaticResource RoleTagText}" Foreground="#0D1523"/>
                        </Border>
                        <TextBlock VerticalAlignment="Center" Margin="10,0,0,0">
                            <Run Text="{Binding Compare.Compare.FileName, Mode=OneWay}" FontFamily="{StaticResource DisplayFont}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}"/>
                            <Run Text=" "/><Run Text="{Binding Compare.Compare.SourceBadge, Mode=OneWay}" FontSize="12" Foreground="{StaticResource MutedBrush}"/><Run Text=" · " FontSize="12" Foreground="{StaticResource MutedBrush}"/><Run Text="{Binding Compare.Compare.TotalText, Mode=OneWay}" FontSize="12" Foreground="{StaticResource MutedBrush}"/><Run Text=" ms" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                        </TextBlock>
                        <Button Style="{StaticResource SubtleButton}" Content="⇄ swap" Command="{Binding SwapCommand}" Margin="18,0,0,0"/>
                    </StackPanel>
                    <TextBlock HorizontalAlignment="Right" TextAlignment="Right" FontSize="12" Foreground="{StaticResource MutedBrush}">
                        <Run Text="Δ = compare − base"/><LineBreak/><Run Text="▼ faster" Foreground="{StaticResource GoodBrush}" FontWeight="Bold"/><Run Text=" · "/><Run Text="▲ slower" Foreground="{StaticResource BadBrush}" FontWeight="Bold"/>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- サマリクラスタ -->
            <Border BorderBrush="{StaticResource HairBrush}" BorderThickness="0,0,0,1" Padding="0,16">
                <UniformGrid Columns="3">
                    <StackPanel Margin="0,0,22,0">
                        <TextBlock Text="Frame time · base → compare" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Compare.FrameText}" Style="{StaticResource NumText}" FontFamily="{StaticResource DisplayFont}" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Compare.FrameSub}" Style="{StaticResource LabelText}" FontSize="11.5" Margin="0,5,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,22,0">
                        <TextBlock Text="Net change" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Compare.NetText}" FontFamily="{StaticResource DisplayFont}" FontSize="20" FontWeight="SemiBold" Typography.NumeralAlignment="Tabular">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Compare.NetState}" Value="{x:Static vm:DeltaState.Good}">
                                            <Setter Property="Foreground" Value="{StaticResource GoodBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Compare.NetState}" Value="{x:Static vm:DeltaState.Bad}">
                                            <Setter Property="Foreground" Value="{StaticResource BadBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding Compare.NetSub}" Style="{StaticResource LabelText}" FontSize="11.5" Margin="0,5,0,0"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Biggest mover" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Compare.BiggestName}" FontFamily="{StaticResource DisplayFont}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}"/>
                        <TextBlock Text="{Binding Compare.BiggestText}" Style="{StaticResource LabelText}" FontSize="11.5" Margin="0,5,0,0"/>
                    </StackPanel>
                </UniformGrid>
            </Border>

            <!-- 予算バー2本(同一目盛) -->
            <Grid Margin="0,30,0,14">
                <TextBlock Text="Frame budget" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="same scale · base above, compare below" Style="{StaticResource LabelText}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                <Border Style="{StaticResource RoleTag}" Background="{StaticResource InkBrush}">
                    <TextBlock Text="BASE" Style="{StaticResource RoleTagText}" Foreground="#15181D"/>
                </Border>
                <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Run Text="{Binding Compare.Base.FileName, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding Compare.Base.TotalText, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource InkBrush}"/><Run Text=" ms" FontWeight="Bold" Foreground="{StaticResource InkBrush}"/>
                </TextBlock>
            </StackPanel>
            <ctl:BudgetBarControl Segments="{Binding Compare.Base.BarSegments}" ShowRuler="False"/>
            <StackPanel Orientation="Horizontal" Margin="0,16,0,7">
                <Border Style="{StaticResource RoleTag}" Background="{StaticResource AccentBrush}">
                    <TextBlock Text="COMPARE" Style="{StaticResource RoleTagText}" Foreground="#0D1523"/>
                </Border>
                <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Run Text="{Binding Compare.Compare.FileName, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding Compare.Compare.TotalText, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource InkBrush}"/><Run Text=" ms" FontWeight="Bold" Foreground="{StaticResource InkBrush}"/>
                </TextBlock>
            </StackPanel>
            <ctl:BudgetBarControl Segments="{Binding Compare.Compare.BarSegments}"/>

            <!-- Per-pass change -->
            <Grid Margin="0,32,0,14">
                <TextBlock Text="Per-pass change" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="sorted by size of change · base is the reference" Style="{StaticResource LabelText}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <Border Background="{StaticResource RaiseBrush}" BorderBrush="{StaticResource HairBrush}" BorderThickness="0,0,0,1">
                        <Grid Margin="0,0,18,0" Height="38">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="84"/>
                                <ColumnDefinition Width="84"/>
                                <ColumnDefinition Width="92"/>
                                <ColumnDefinition Width="170"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="Pass" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Grid.Column="2" Text="Base" VerticalAlignment="Center" TextAlignment="Right" FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Grid.Column="3" Text="Compare" VerticalAlignment="Center" TextAlignment="Right" FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Grid.Column="4" Text="Δ ms" VerticalAlignment="Center" TextAlignment="Right" FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Grid.Column="5" Text="change" VerticalAlignment="Center" Margin="24,0,0,0" FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                        </Grid>
                    </Border>
                    <ItemsControl ItemsSource="{Binding Compare.Rows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                <Border BorderThickness="0,0,0,1" MouseLeftButtonUp="Row_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{StaticResource HairBrush}"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <!-- ネスト行は罫線を消して親の塊として見せる -->
                                                <DataTrigger Binding="{Binding IsNested}" Value="True">
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </DataTrigger>
                                                <!-- 画像を持つ行だけクリック可能に見せる -->
                                                <DataTrigger Binding="{Binding HasImages}" Value="True">
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                </DataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding HasImages}" Value="True"/>
                                                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="{StaticResource RaiseBrush}"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid Margin="0,0,18,0">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Height" Value="50"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsNested}" Value="True">
                                                        <Setter Property="Height" Value="34"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="84"/>
                                            <ColumnDefinition Width="84"/>
                                            <ColumnDefinition Width="92"/>
                                            <ColumnDefinition Width="170"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="4" Background="{Binding CatBrush}" HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Height" Value="30"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsNested}" Value="True">
                                                            <Setter Property="Height" Value="20"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="{Binding Indent}">
                                            <TextBlock Text="{Binding Name}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontSize" Value="14"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsNested}" Value="True">
                                                                <Setter Property="FontSize" Value="12.5"/>
                                                                <Setter Property="FontWeight" Value="Normal"/>
                                                                <Setter Property="Foreground" Value="{StaticResource Ink2Brush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding CountText}" FontSize="10.5" Foreground="{StaticResource FaintBrush}"
                                                       Margin="6,1,0,0" VerticalAlignment="Center"/>
                                            <Border Background="{StaticResource GoodBgBrush}" Padding="6,2" Margin="8,0,0,0"
                                                    Visibility="{Binding IsNew, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="NEW" FontSize="9" FontWeight="Bold" Foreground="{StaticResource GoodBrush}"/>
                                            </Border>
                                            <Border Background="{StaticResource RaiseBrush}" Padding="6,2" Margin="8,0,0,0"
                                                    Visibility="{Binding IsGone, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="GONE" FontSize="9" FontWeight="Bold" Foreground="{StaticResource MutedBrush}"/>
                                            </Border>
                                            <Border Background="{StaticResource RaiseBrush}" Padding="6,2" Margin="8,0,0,0"
                                                    Visibility="{Binding HasImages, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{Binding ImageCountText}" FontSize="9" FontWeight="Bold" Foreground="{StaticResource MutedBrush}"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding BaseText}" VerticalAlignment="Center" TextAlignment="Right"
                                                   Style="{StaticResource NumText}" FontSize="14" Foreground="{StaticResource MutedBrush}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding CompareText}" VerticalAlignment="Center" TextAlignment="Right"
                                                   Style="{StaticResource NumText}" FontSize="14.5" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="4" Text="{Binding DeltaText}" VerticalAlignment="Center" TextAlignment="Right"
                                                   FontSize="15" FontWeight="Bold" Typography.NumeralAlignment="Tabular">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource FaintBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding State}" Value="{x:Static vm:DeltaState.Good}">
                                                            <Setter Property="Foreground" Value="{StaticResource GoodBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding State}" Value="{x:Static vm:DeltaState.Bad}">
                                                            <Setter Property="Foreground" Value="{StaticResource BadBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- 発散バー(中央線、緑=改善は左、赤=悪化は右) -->
                                        <Grid Grid.Column="5" Margin="24,0,0,0" Height="24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.ColumnSpan="2" Width="1.5" Background="{StaticResource Hair2Brush}" HorizontalAlignment="Center"/>
                                            <Border Grid.Column="0" Background="{StaticResource GoodBrush}" Height="11" HorizontalAlignment="Right"
                                                    Width="{Binding BarFraction, Converter={StaticResource FractionToWidth}, ConverterParameter=70}"
                                                    Visibility="{Binding State, Converter={StaticResource DeltaGoodToVis}}"/>
                                            <Border Grid.Column="1" Background="{StaticResource BadBrush}" Height="11" HorizontalAlignment="Left"
                                                    Width="{Binding BarFraction, Converter={StaticResource FractionToWidth}, ConverterParameter=70}"
                                                    Visibility="{Binding State, Converter={StaticResource DeltaBadToVis}}"/>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- 画像ドロワー: base / compare の抽出画像を並べて見せる -->
                                <Border Background="{StaticResource RaiseBrush}" BorderBrush="{Binding CatBrush}" BorderThickness="4,0,0,0"
                                        Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}" Padding="22,16,22,8">
                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0,0,18,0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <Border Style="{StaticResource RoleTag}" Background="{StaticResource InkBrush}">
                                                    <TextBlock Text="BASE" Style="{StaticResource RoleTagText}" Foreground="#15181D"/>
                                                </Border>
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{Binding BasePass.Images}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="{StaticResource Hair2Brush}" BorderThickness="1"
                                                                Margin="0,0,10,10" Padding="3" Background="{StaticResource SurfaceBrush}"
                                                                Cursor="Hand" MouseLeftButtonUp="Thumbnail_Click" Tag="{Binding PngPath}">
                                                            <StackPanel>
                                                                <Image Source="{Binding PngPath}" Height="96" Stretch="Uniform"/>
                                                                <TextBlock Text="{Binding ResourceName}" FontSize="10.5" Foreground="{StaticResource MutedBrush}"
                                                                           Margin="2,3,2,1" MaxWidth="170" TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="no extracted image — extract in single view" Style="{StaticResource LabelText}"
                                                       FontSize="11.5" Margin="0,0,0,10"
                                                       Visibility="{Binding BaseHasImages, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <Border Style="{StaticResource RoleTag}" Background="{StaticResource AccentBrush}">
                                                    <TextBlock Text="COMPARE" Style="{StaticResource RoleTagText}" Foreground="#0D1523"/>
                                                </Border>
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{Binding ComparePass.Images}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="{StaticResource Hair2Brush}" BorderThickness="1"
                                                                Margin="0,0,10,10" Padding="3" Background="{StaticResource SurfaceBrush}"
                                                                Cursor="Hand" MouseLeftButtonUp="Thumbnail_Click" Tag="{Binding PngPath}">
                                                            <StackPanel>
                                                                <Image Source="{Binding PngPath}" Height="96" Stretch="Uniform"/>
                                                                <TextBlock Text="{Binding ResourceName}" FontSize="10.5" Foreground="{StaticResource MutedBrush}"
                                                                           Margin="2,3,2,1" MaxWidth="170" TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="no extracted image — extract in single view" Style="{StaticResource LabelText}"
                                                       FontSize="11.5" Margin="0,0,0,10"
                                                       Visibility="{Binding CompareHasImages, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                        </StackPanel>
                                    </UniformGrid>
                                </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            <TextBlock Text="{Binding Compare.Note}" Style="{StaticResource LabelText}" Margin="0,14,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl>
